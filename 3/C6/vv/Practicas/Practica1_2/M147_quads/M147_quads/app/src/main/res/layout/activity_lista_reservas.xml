<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ORDENAR POR:"
        android:gravity="center"
        android:textStyle="italic"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleGroupReservas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:checkedButton="@id/sort_fecha_in">

        <!-- BOTÓN 1: CLIENTE -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/sort_cliente"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CLIENTE"
            android:textSize="9sp"
            android:padding="0dp"
            app:strokeColor="@color/colorBtnEdit"
            android:textColor="@color/black"/> 
            <!-- ELIMINADO app:backgroundTint, CAMBIADO textColor a black -->

        <!-- BOTÓN 2: TELÉFONO -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/sort_telefono"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TLF"
            android:textSize="9sp"
            android:padding="0dp"
            app:strokeColor="@color/colorBtnEdit"
            android:textColor="@color/black"/>

        <!-- BOTÓN 3: ENTRADA -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/sort_fecha_in"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ENTRADA"
            android:textSize="9sp"
            android:padding="0dp"
            app:strokeColor="@color/colorBtnEdit"
            android:textColor="@color/black"/>

        <!-- BOTÓN 4: SALIDA -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/sort_fecha_out"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SALIDA"
            android:textSize="9sp"
            android:padding="0dp"
            app:strokeColor="@color/colorBtnEdit"
            android:textColor="@color/black"/>

    </com.google.android.material.button.MaterialButtonToggleGroup>
    
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerview_reservas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        tools:listitem="@layout/item_reserva"/>

    <!-- NUEVO: TEXTO LISTA VACÍA -->
    <TextView
        android:id="@+id/empty_view_reservas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="@string/no_data_reservas"
        android:textColor="@android:color/darker_gray"
        android:textSize="18sp"
        android:visibility="gone"/>

</LinearLayout>