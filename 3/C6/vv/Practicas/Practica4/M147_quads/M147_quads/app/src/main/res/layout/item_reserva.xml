<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:background="@color/colorListHeader"
    android:elevation="2dp">

    <!-- Fila 1: Nombre Cliente y Teléfono (Sin cambios) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">
        
        <TextView
            android:id="@+id/tv_res_cliente"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Nombre Cliente"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/black"/>

        <TextView
            android:id="@+id/tv_res_telefono"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="600 000 000"
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray"/>
    </LinearLayout>

    <!-- Fila 2: Fechas (Sin cambios) -->
    <TextView
        android:id="@+id/tv_res_fechas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="01/01/2024 -> 05/01/2024"
        android:textStyle="italic"
        android:textColor="@color/colorBtnEdit"
        android:layout_marginBottom="8dp"/>

    <!-- Separador -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#CCCCCC"
        android:layout_marginBottom="8dp"/>

    <!-- ============================================= -->
    <!-- BLOQUE DE BOTONES (2 FILAS x 2 COLUMNAS)      -->
    <!-- ============================================= -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- PRIMERA FILA DE BOTONES: DETALLES y ENVIAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp"
            android:weightSum="2">

            <!-- Botón DETALLES -->
            <Button
                android:id="@+id/btnDetailsReserva"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:backgroundTint="@color/colorBtnEdit"
                android:text="DETALLES"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginEnd="4dp"/>

            <!-- Botón ENVIAR (Ahora MARRÓN) -->
            <Button
                android:id="@+id/btnSendReserva"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:backgroundTint="@color/colorBtnEdit"
                android:text="ENVIAR"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- SEGUNDA FILA DE BOTONES: EDITAR y BORRAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <!-- Botón EDITAR -->
            <Button
                android:id="@+id/btnEditReserva"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:backgroundTint="@color/colorBtnEdit"
                android:text="EDITAR"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginEnd="4dp"/>

            <!-- Botón BORRAR (Rojo) -->
            <Button
                android:id="@+id/btnDeleteReserva"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:backgroundTint="@color/colorBtnDelete"
                android:text="BORRAR"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>