<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:minHeight="95dp"
    android:background="@color/app_background_pastel"
    android:layout_marginBottom="2dp">

    <!-- CHECKBOX: Recuadro de selección más grande -->
    <CheckBox
        android:id="@+id/cb_select"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:buttonTint="@color/colorBtnEdit"
        android:scaleX="1.3"
        android:scaleY="1.3"
        android:layout_marginEnd="4dp" />

    <!-- Información del vehículo (Matrícula y Tipo) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/tv_matricula"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0000-AAA"
            android:textStyle="bold"
            android:textSize="17sp"
            android:textColor="@color/black"/>

        <TextView
            android:id="@+id/tv_tipo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monoplaza"
            android:textSize="13sp"
            android:textStyle="italic"
            android:textColor="@android:color/darker_gray"/>
    </LinearLayout>

    <!-- COLUMNA INFO: Alineada con la de Cascos -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginEnd="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DETALLES"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="@color/colorBtnEdit"
            android:layout_marginBottom="2dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_details_selection"
            android:layout_width="70dp"
            android:layout_height="48dp"
            android:text="VER"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:backgroundTint="@color/colorBtnEdit"
            app:cornerRadius="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />
    </LinearLayout>

    <!-- COLUMNA CASCOS: Estructura idéntica para coherencia total -->
    <LinearLayout
        android:id="@+id/layout_cascos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CASCOS"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="@color/colorBtnEdit"
            android:layout_marginBottom="2dp"/>

        <!-- BOTÓN CON FLECHA INTEGRADA: Sin fluorescencia -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cascos_popup"
            android:layout_width="80dp"
            android:layout_height="48dp"
            android:text="1"
            android:textSize="16sp"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/colorBtnEdit"
            app:cornerRadius="8dp"
            app:icon="@android:drawable/arrow_down_float"
            app:iconTint="@android:color/white"
            app:iconTintMode="src_in"
            app:iconGravity="textEnd"
            app:iconPadding="2dp"
            app:iconSize="14dp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />
    </LinearLayout>

</LinearLayout>