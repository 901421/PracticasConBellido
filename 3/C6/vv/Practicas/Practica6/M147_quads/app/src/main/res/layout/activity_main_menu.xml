<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp"
        tools:context=".ui.SistemaReservas">

        <!-- LOGO (Mantenido tamaño original pero dentro de Scroll) -->
        <ImageView
            android:id="@+id/logo_app"
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:src="@drawable/logo"
            android:contentDescription="Logo de la aplicación"
            android:layout_marginBottom="32dp"/>

        <!-- BOTÓN 1: CREAR QUAD -->
        <Button
            android:id="@+id/button_crear_quad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Crear Quad"
            android:textSize="20sp"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/colorBtnEdit"
            android:textAllCaps="false"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>

        <!-- BOTÓN 2: LISTAR QUADS -->
        <Button
            android:id="@+id/button_listar_quads"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Listar Quads"
            android:textSize="20sp"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/colorBtnEdit"
            android:textAllCaps="false"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>

        <!-- BOTÓN 3: CREAR RESERVA -->
        <Button
            android:id="@+id/button_crear_reserva"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Crear Reserva"
            android:textSize="20sp"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/colorBtnEdit"
            android:textAllCaps="false"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>

        <!-- BOTÓN 4: LISTAR RESERVAS -->
        <Button
            android:id="@+id/button_listar_reservas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Listar Reservas"
            android:textSize="20sp"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/colorBtnEdit"
            android:textAllCaps="false"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>

        <!-- BOTÓN ACCESO A PRUEBAS -->
        <Button
            android:id="@+id/button_panel_pruebas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Panel de Pruebas"
            android:textSize="20sp"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/colorBtnTest"
            android:textAllCaps="false"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:visibility="gone"/>

        <!-- ESPACIADOR INFERIOR DE SEGURIDAD PARA ESPRESSO -->
        <View
            android:layout_width="match_parent"
            android:layout_height="150dp"/>

    </LinearLayout>
</ScrollView>
