<?xml version="1.0" encoding="utf-8"?>
<!-- Cambiamos la raíz a un LinearLayout vertical para separar el contenido de los botones -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- El ScrollView ahora tiene weight="1", lo que empuja los botones hacia abajo -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- SECCIÓN: CLIENTE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_cliente"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:textSize="18sp" />

            <EditText
                android:id="@+id/edit_cliente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombre del cliente"
                android:textColorHint="@android:color/darker_gray"
                android:inputType="textPersonName"
                android:minHeight="48dp"
                android:textSize="18sp" />

            <!-- SECCIÓN: TELÉFONO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/label_telefono"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:textSize="18sp" />

            <EditText
                android:id="@+id/edit_telefono"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="000 000 000"
                android:textColorHint="@android:color/darker_gray"
                android:inputType="phone"
                android:minHeight="48dp"
                android:textSize="18sp" />

            <!-- SECCIÓN: FECHAS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_fecha_recogida"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:textSize="16sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_fecha_recogida"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="SELECCIONAR"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/colorBtnEdit"
                        app:cornerRadius="8dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_fecha_devolucion"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:textSize="16sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_fecha_devolucion"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="SELECCIONAR"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/colorBtnEdit"
                        app:cornerRadius="8dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- SECCIÓN: QUADS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/label_quads"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:textSize="18sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_select_quads"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginTop="8dp"
                android:text="SELECCIONAR"
                app:backgroundTint="@color/colorBtnEdit"
                app:cornerRadius="8dp"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="(Pulsa para añadir o quitar vehículos)"
                android:gravity="center"
                android:textSize="12sp"
                android:textColor="@android:color/darker_gray"
                android:layout_marginBottom="16dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- LOS BOTONES DE ACCIÓN AHORA ESTÁN FUERA DEL SCROLLVIEW -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/button_cancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/btn_cancelar"
            android:backgroundTint="#CCCCCC"
            android:textColor="@android:color/black"/>

        <Button
            android:id="@+id/button_confirm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/btn_confirmar"
            android:backgroundTint="@color/colorBtnEdit"
            android:textColor="@android:color/white"/>
    </LinearLayout>

</LinearLayout>